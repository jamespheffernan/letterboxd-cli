# Optional lbd defaults. Copy to your shell profile or local environment.
# Do not put real cookies in files that may be committed.

# LETTERBOXD_DB=~/.letterboxd-cli/letterboxd.sqlite3
# LETTERBOXD_SESSION_FILE=~/.letterboxd-cli/session.json
# LETTERBOXD_BASE_URL=https://letterboxd.com

# Prefer JSON stdout for commands that support structured output.
# LETTERBOXD_JSON=1

# Prefer stable plain/CSV output where available.
# LETTERBOXD_PLAIN=1

# Never read from clipboard or stdin; useful for CI and agents.
# LETTERBOXD_NO_INPUT=1

# One-off only. Prefer passing this in your shell, not storing it here.
# LETTERBOXD_COOKIE=letterboxd_session=...
